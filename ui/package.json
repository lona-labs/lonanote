{
  "$schema": "https://json.schemastore.org/package",
  "name": "lonanote",
  "version": "0.0.1",
  "type": "module",
  "description": "LonaNote",
  "scripts": {
    "dev": "tauri dev",
    "dev-android": "pnpm tauri android dev --open",
    "dev-ios": "pnpm tauri ios dev --open --host",
    "build": "tauri build",
    "build-android": "pnpm tauri android build --open",
    "build-ios": "pnpm tauri ios build --open",
    "build-debug": "tauri build --debug",
    "icon-gen": "node ./scripts/utils/icon.cjs --input ./public/icon.png",
    "web-dev": "vite --force",
    "web-build": "pnpm web-lint&&vite build",
    "web-lint": "npx eslint src",
    "tauri": "tauri",
    "format": "prettier --write src"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.1.1",
    "@tauri-apps/plugin-clipboard-manager": "^2.0.1",
    "@tauri-apps/plugin-dialog": "^2.0.1",
    "@tauri-apps/plugin-fs": "^2.0.3",
    "@tauri-apps/plugin-log": "^2.0.1",
    "@tauri-apps/plugin-os": "^2.0.0",
    "@tauri-apps/plugin-shell": "^2.0.1",
    "clsx": "^2.1.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-responsive": "^10.0.0",
    "react-toastify": "^10.0.6",
    "vconsole": "^3.15.1",
    "vditor": "^3.10.8",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@eslint/compat": "^1.2.4",
    "@tauri-apps/cli": "^2.1.0",
    "@trivago/prettier-plugin-sort-imports": "^5.1.0",
    "@types/node": "^22",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.1",
    "@typescript-eslint/eslint-plugin": "^8.17.0",
    "@typescript-eslint/parser": "^8.17.0",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.16.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react-hooks": "^5.1.0-rc-cae764ce-20241025",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.13.0",
    "icon-gen": "^5.0.0",
    "png-to-ico": "^2.1.8",
    "prettier": "^3.4.2",
    "sass-embedded": "^1.82.0",
    "sharp": "^0.33.5",
    "ts-deepmerge": "^7.0.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vite-plugin-vconsole": "^2.1.1",
    "walkdir": "^0.4.1"
  },
  "packageManager": "pnpm@9.5.0",
  "node": ">=20.0.0"
}
