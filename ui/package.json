{
  "name": "lonanote",
  "version": "0.0.1",
  "description": "lonanote",
  "main": "./out/main/index.js",
  "author": "lona-labs",
  "homepage": "https://github.com/lona-labs/lonanote",
  "type": "module",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint . --ext .js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "pnpm run typecheck:node && pnpm run typecheck:web",
    "start": "electron-vite preview",
    "dev": "pnpm run build:rust:node && electron-vite dev",
    "dev:web": "vite --force",
    "dev:android": "pnpm tauri:cmd android dev --open",
    "dev:ios": "pnpm tauri:cmd ios dev --open --host",
    "build": "pnpm run build:rust:node && pnpm run build:web",
    "build:web": "pnpm run typecheck && electron-vite build",
    "build:android": "pnpm tauri:cmd android build --open",
    "build:ios": "pnpm tauri:cmd ios build --open",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "pnpm run build && electron-builder --dir",
    "build:win": "pnpm run build && electron-builder --win",
    "build:mac": "pnpm run build && electron-builder --mac",
    "build:linux": "pnpm run build && electron-builder --linux",
    "build:rust:node": "cd ../rust/node/&&pnpm build&&cd ../../ui/",
    "tauri:cmd": "env-cmd -f scripts/env/tauri.env -- tauri"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "electron-store": "^10.0.0",
    "electron-updater": "^6.3.9",
    "lonanote-core-node": "link:../rust/node"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "^2.0.0",
    "@electron-toolkit/eslint-config-ts": "^2.0.0",
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@tauri-apps/cli": "^2.1.0",
    "@trivago/prettier-plugin-sort-imports": "^5.2.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.2.1",
    "electron-builder": "^26.0.0-alpha.6",
    "electron-vite": "^2.3.0",
    "env-cmd": "^10.1.0",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.37.2",
    "prettier": "^3.4.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-toastify": "^10.0.6",
    "sass-embedded": "^1.83.0",
    "ts-deepmerge": "^7.0.2",
    "typescript": "^5.7.2",
    "vite": "^5.4.11",
    "walkdir": "^0.4.1"
  },
  "packageManager": "pnpm@9.15.0",
  "node": ">=20.0.0"
}
